{
    "name": "app",
    "version": "1.0.0",
    "AWSTemplateFormatVersion": {
        "description": "2010-09-09"
    },
    "Conditions": {
        "IsProduction": {
            "Fn::Equals": [
                { "Ref": "Environment" },
                "production"
            ]
        }
    },
    "Parameters": {
        "Environment": {
            "Type": "String",
            "Default": "development",
            "AllowedValues": ["production", "staging", "development"],
            "Description": "Hedef dağıtım ortamı"
        }
    }
}